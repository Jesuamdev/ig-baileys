# ────────────────────────────────────────
# SERVIDOR
# ────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5500

# ────────────────────────────────────────
# BASE DE DATOS PostgreSQL
# ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=corpease_unified
DB_USER=postgres
DB_PASSWORD=tu_password_aqui

# ────────────────────────────────────────
# JWT
# ────────────────────────────────────────
JWT_SECRET=CorpEaseUnifiedSuperSecretKey2026!
JWT_EXPIRES_IN=7d

# ────────────────────────────────────────
# WHATSAPP (Meta Cloud API)
# ────────────────────────────────────────
WHATSAPP_TOKEN=tu_access_token_permanente
WHATSAPP_PHONE_ID=tu_phone_number_id
WHATSAPP_BUSINESS_ID=tu_business_account_id
WHATSAPP_VERIFY_TOKEN=token_verificacion_webhook

# ────────────────────────────────────────
# ALMACENAMIENTO DE ARCHIVOS
# ────────────────────────────────────────
# Opciones: "local" o "s3"
STORAGE_TYPE=local
UPLOADS_PATH=./uploads

# Solo si STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=corpease-archivos

# ────────────────────────────────────────
# EMAIL (Resend)
# ────────────────────────────────────────
RESEND_API_KEY=re_tu_api_key
EMAIL_FROM=noreply@corpease.com
EMAIL_FROM_NAME=CorpEase

# ────────────────────────────────────────
# WORDPRESS (opcional)
# ────────────────────────────────────────
WP_WEBHOOK_SECRET=tu_token_secreto_wordpress
WP_SITE_URL=https://tu-sitio.com
