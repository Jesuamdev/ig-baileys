{
  "name": "corpease-unified-backend",
  "version": "2.0.0",
  "description": "CorpEase CRM + WhatsApp Panel — Sistema Unificado",
  "main": "src/index.js",
  "scripts": {
    "dev":         "nodemon src/index.js",
